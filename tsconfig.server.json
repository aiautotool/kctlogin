{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "skipLibCheck": true,
    "strict": true,
    "outDir": "dist-server",
    "rootDir": ".",
    "declaration": false,
    "sourceMap": false
  },
  "include": ["server/**/*.ts"]
}
